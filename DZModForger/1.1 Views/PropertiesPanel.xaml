<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.PropertiesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DZModForger">

    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" 
            Text="Properties" 
            Padding="12,8" 
            FontWeight="Bold" 
            FontSize="14" />

        <ScrollViewer Grid.Row="1" VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="12" Spacing="16">

                <!-- Transform Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Transform" FontWeight="SemiBold" Foreground="#32a8c6" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Position" FontSize="12" />
                        <Grid ColumnDefinitions="40,*,40,*,40,*" ColumnSpacing="4">
                            <TextBlock Text="X:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding PositionX, Mode=TwoWay}" />
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="3" Text="{Binding PositionY, Mode=TwoWay}" />
                            <TextBlock Grid.Column="4" Text="Z:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding PositionZ, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Rotation (°)" FontSize="12" />
                        <Grid ColumnDefinitions="40,*,40,*,40,*" ColumnSpacing="4">
                            <TextBlock Text="X:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding RotationX, Mode=TwoWay}" />
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="3" Text="{Binding RotationY, Mode=TwoWay}" />
                            <TextBlock Grid.Column="4" Text="Z:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding RotationZ, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Scale" FontSize="12" />
                        <Grid ColumnDefinitions="40,*,40,*,40,*" ColumnSpacing="4">
                            <TextBlock Text="X:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding ScaleX, Mode=TwoWay}" />
                            <TextBlock Grid.Column="2" Text="Y:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="3" Text="{Binding ScaleY, Mode=TwoWay}" />
                            <TextBlock Grid.Column="4" Text="Z:" VerticalAlignment="Center" />
                            <TextBox Grid.Column="5" Text="{Binding ScaleZ, Mode=TwoWay}" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Material Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Material" FontWeight="SemiBold" Foreground="#32a8c6" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Diffuse Color" FontSize="12" />
                        <Grid ColumnDefinitions="*,50" ColumnSpacing="4">
                            <TextBox PlaceholderText="RGB Hex" Text="{Binding DiffuseColorHex, Mode=TwoWay}" />
                            <Button Grid.Column="1" 
                                Background="{Binding DiffuseColorBrush}"
                                Content="◆"
                                Clicked="DiffuseColor_Click" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Specular Color" FontSize="12" />
                        <Grid ColumnDefinitions="*,50" ColumnSpacing="4">
                            <TextBox PlaceholderText="RGB Hex" Text="{Binding SpecularColorHex, Mode=TwoWay}" />
                            <Button Grid.Column="1"
                                Background="{Binding SpecularColorBrush}"
                                Content="◆"
                                Clicked="SpecularColor_Click" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,60">
                            <TextBlock Text="Shininess" />
                            <TextBlock Grid.Column="1" Text="{Binding Shininess}" TextAlignment="Right" />
                        </Grid>
                        <Slider 
                            Minimum="0"
                            Maximum="128"
                            Value="{Binding Shininess, Mode=TwoWay}"
                            StepFrequency="1" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <Grid ColumnDefinitions="*,60">
                            <TextBlock Text="Opacity" />
                            <TextBlock Grid.Column="1" Text="{Binding Opacity, StringFormat=0.00}" TextAlignment="Right" />
                        </Grid>
                        <Slider 
                            Minimum="0"
                            Maximum="1"
                            Value="{Binding Opacity, Mode=TwoWay}"
                            StepFrequency="0.01" />
                    </StackPanel>
                </StackPanel>

                <!-- Display Options -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Display" FontWeight="SemiBold" Foreground="#32a8c6" />

                    <CheckBox Content="Visible" IsChecked="{Binding IsVisible, Mode=TwoWay}" />
                    <CheckBox Content="Wireframe" IsChecked="{Binding ShowWireframe, Mode=TwoWay}" />
                    <CheckBox Content="Show Normals" IsChecked="{Binding ShowNormals, Mode=TwoWay}" />
                    <CheckBox Content="Show Tangents" IsChecked="{Binding ShowTangents, Mode=TwoWay}" />
                    <CheckBox Content="Smooth Shading" IsChecked="{Binding SmoothShading, Mode=TwoWay}" />
                </StackPanel>

                <!-- Advanced -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Advanced" FontWeight="SemiBold" Foreground="#32a8c6" />

                    <Grid ColumnDefinitions="*,60">
                        <TextBlock Text="Emissive" VerticalAlignment="Center" />
                        <Slider Grid.Column="1" Margin="12,0,0,0" />
                    </Grid>

                    <CheckBox Content="Cast Shadow" IsChecked="True" />
                    <CheckBox Content="Receive Shadow" IsChecked="True" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
