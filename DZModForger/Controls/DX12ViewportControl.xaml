<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.Controls.DX12ViewportControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1a1a1a"
    Foreground="{StaticResource TextPrimaryBrush}">

    <Grid Background="#1a1a1a">
        <Canvas x:Name="ViewportCanvas" Background="#1a1a1a"/>

        <!-- Viewport HUD Overlay -->
        <StackPanel
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Spacing="12"
            Padding="16"
            Orientation="Vertical">

            <!-- FPS Counter -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    Text="FPS:"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    VerticalAlignment="Center"/>
                <TextBlock
                    x:Name="FPSCounter"
                    Text="0"
                    FontSize="12"
                    Foreground="{StaticResource SuccessBrush}"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Camera Info -->
            <TextBlock
                x:Name="CameraInfoText"
                Text="Camera: (0.0, 0.0, 0.0)"
                FontSize="11"
                Foreground="{StaticResource TextSecondaryBrush}"/>

            <!-- Status -->
            <TextBlock
                x:Name="StatusText"
                Text="Ready"
                FontSize="11"
                Foreground="{StaticResource TextSecondaryBrush}"/>
        </StackPanel>

        <!-- Bottom Right - Statistics -->
        <StackPanel
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            Spacing="8"
            Padding="16"
            Orientation="Vertical"
            Background="#00000080">

            <TextBlock
                Text="Statistics"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource AccentBrush}"/>

            <Grid ColumnSpacing="12" RowSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Vertices:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock
                    Grid.Column="1"
                    x:Name="StatVertices"
                    Text="0"
                    FontSize="11"
                    Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Row="1" Text="Faces:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock
                    Grid.Row="1"
                    Grid.Column="1"
                    x:Name="StatFaces"
                    Text="0"
                    FontSize="11"
                    Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Grid.Row="2" Text="GPU Mem:" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="1"
                    x:Name="StatGPUMemory"
                    Text="0 MB"
                    FontSize="11"
                    Foreground="{StaticResource TextPrimaryBrush}"/>
            </Grid>
        </StackPanel>

        <!-- Center Crosshair -->
        <Canvas VerticalAlignment="Center" HorizontalAlignment="Center">
            <Line
                X1="-20" Y1="0"
                X2="20" Y2="0"
                Stroke="#FF4FC3F7"
                StrokeThickness="1"
                Opacity="0.5"/>
            <Line
                X1="0" Y1="-20"
                X2="0" Y2="20"
                Stroke="#FF4FC3F7"
                StrokeThickness="1"
                Opacity="0.5"/>
        </Canvas>
    </Grid>
</UserControl>
