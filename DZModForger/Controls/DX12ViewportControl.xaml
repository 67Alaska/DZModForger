<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.Controls.DX12ViewportControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#FF0D0D0D"
    BorderBrush="#FF3F3F3F"
    BorderThickness="1">

	<Grid Background="#FF0D0D0D">
		<Grid.RowDefinitions>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Main Viewport Canvas -->
		<Canvas
            Grid.Row="0"
            x:Name="ViewportCanvas"
            Background="#FF1A1A1A"
            MouseMove="ViewportCanvas_MouseMove"
            MouseWheel="ViewportCanvas_MouseWheel"
            MouseLeftButtonDown="ViewportCanvas_MouseLeftButtonDown"
            MouseLeftButtonUp="ViewportCanvas_MouseLeftButtonUp"
            MouseRightButtonDown="ViewportCanvas_MouseRightButtonDown"
            MouseRightButtonUp="ViewportCanvas_MouseRightButtonUp">

			<!-- Viewport Overlay Info -->
			<StackPanel
                Canvas.Left="12"
                Canvas.Top="12"
                Orientation="Vertical"
                Spacing="4"
                Panel.ZIndex="10">

				<!-- FPS Counter -->
				<TextBlock
                    x:Name="FPSCounter"
                    Text="FPS: 120"
                    Foreground="#FF4FC3F7"
                    FontSize="12"
                    FontWeight="SemiBold"
                    FontFamily="Courier New"/>

				<!-- Resolution Display -->
				<TextBlock
                    x:Name="ResolutionDisplay"
                    Text="1600 x 1000"
                    Foreground="#FFA0A0A0"
                    FontSize="11"
                    FontFamily="Courier New"/>

				<!-- Camera Info -->
				<TextBlock
                    x:Name="CameraInfo"
                    Text="Cam: (0.0, 0.0, 5.0)"
                    Foreground="#FFA0A0A0"
                    FontSize="11"
                    FontFamily="Courier New"/>

				<!-- Grid Indicator -->
				<TextBlock
                    x:Name="GridIndicator"
                    Text="Grid: ON"
                    Foreground="#FF00FF00"
                    FontSize="11"
                    FontWeight="SemiBold"
                    FontFamily="Courier New"/>
			</StackPanel>

			<!-- Viewport Controls (Top Right) -->
			<StackPanel
                Canvas.Right="12"
                Canvas.Top="12"
                Orientation="Vertical"
                Spacing="8"
                Panel.ZIndex="10">

				<!-- View Preset Buttons -->
				<StackPanel Orientation="Horizontal" Spacing="4">
					<Button
                        x:Name="BtnViewFront"
                        Content="⬅ Front"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnViewFront_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Front View (F)"/>

					<Button
                        x:Name="BtnViewTop"
                        Content="⬆ Top"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnViewTop_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Top View (T)"/>

					<Button
                        x:Name="BtnViewSide"
                        Content="➡ Side"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnViewSide_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Side View (S)"/>

					<Button
                        x:Name="BtnViewIso"
                        Content="⬈ ISO"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnViewIso_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Isometric View (I)"/>
				</StackPanel>

				<!-- Shading Mode Buttons -->
				<StackPanel Orientation="Horizontal" Spacing="4">
					<Button
                        x:Name="BtnWireframe"
                        Content="🔲 Wire"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnWireframe_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Wireframe Mode"/>

					<Button
                        x:Name="BtnSolid"
                        Content="⬤ Solid"
                        Width="70"
                        Height="28"
                        Background="#FF4FC3F7"
                        Foreground="#FF1A1A1A"
                        Click="BtnSolid_Click"
                        FontSize="11"
                        FontWeight="SemiBold"
                        ToolTipService.ToolTip="Solid Shading"/>

					<Button
                        x:Name="BtnMaterial"
                        Content="🎨 Mat"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnMaterial_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Material Mode"/>

					<Button
                        x:Name="BtnRender"
                        Content="💡 Render"
                        Width="70"
                        Height="28"
                        Background="#FF252525"
                        Foreground="#FFFFFFFF"
                        Click="BtnRender_Click"
                        FontSize="11"
                        ToolTipService.ToolTip="Render Mode"/>
				</StackPanel>
			</StackPanel>

			<!-- Center Crosshair -->
			<Canvas
                Canvas.Left="800"
                Canvas.Top="500"
                Width="40"
                Height="40"
                Panel.ZIndex="5">

				<!-- Horizontal Line -->
				<Line
                    X1="0"
                    Y1="20"
                    X2="40"
                    Y2="20"
                    Stroke="#FF4FC3F7"
                    StrokeThickness="1"
                    Opacity="0.3"/>

				<!-- Vertical Line -->
				<Line
                    X1="20"
                    Y1="0"
                    X2="20"
                    Y2="40"
                    Stroke="#FF4FC3F7"
                    StrokeThickness="1"
                    Opacity="0.3"/>

				<!-- Center Dot -->
				<Ellipse
                    Canvas.Left="18"
                    Canvas.Top="18"
                    Width="4"
                    Height="4"
                    Fill="#FF4FC3F7"
                    Opacity="0.5"/>
			</Canvas>

			<!-- Bottom Left Controls -->
			<StackPanel
                Canvas.Left="12"
                Canvas.Bottom="12"
                Orientation="Horizontal"
                Spacing="8"
                Panel.ZIndex="10">

				<!-- Grid Toggle -->
				<CheckBox
                    x:Name="ChkShowGrid"
                    Content="Show Grid"
                    Foreground="#FFFFFFFF"
                    IsChecked="True"
                    Checked="ChkShowGrid_Checked"
                    Unchecked="ChkShowGrid_Unchecked"
                    VerticalAlignment="Center"
                    FontSize="12"/>

				<!-- Axes Toggle -->
				<CheckBox
                    x:Name="ChkShowAxes"
                    Content="Show Axes"
                    Foreground="#FFFFFFFF"
                    IsChecked="True"
                    Checked="ChkShowAxes_Checked"
                    Unchecked="ChkShowAxes_Unchecked"
                    VerticalAlignment="Center"
                    FontSize="12"/>

				<!-- Bounds Toggle -->
				<CheckBox
                    x:Name="ChkShowBounds"
                    Content="Show Bounds"
                    Foreground="#FFFFFFFF"
                    IsChecked="False"
                    Checked="ChkShowBounds_Checked"
                    Unchecked="ChkShowBounds_Unchecked"
                    VerticalAlignment="Center"
                    FontSize="12"/>
			</StackPanel>

			<!-- Bottom Right Stats -->
			<StackPanel
                Canvas.Right="12"
                Canvas.Bottom="12"
                Orientation="Vertical"
                Spacing="2"
                Panel.ZIndex="10"
                HorizontalAlignment="Right">

				<TextBlock
                    x:Name="StatVertices"
                    Text="Vertices: 0"
                    Foreground="#FFA0A0A0"
                    FontSize="10"
                    FontFamily="Courier New"
                    TextAlignment="Right"/>

				<TextBlock
                    x:Name="StatFaces"
                    Text="Faces: 0"
                    Foreground="#FFA0A0A0"
                    FontSize="10"
                    FontFamily="Courier New"
                    TextAlignment="Right"/>

				<TextBlock
                    x:Name="StatGPUMemory"
                    Text="GPU Memory: 0 MB"
                    Foreground="#FFA0A0A0"
                    FontSize="10"
                    FontFamily="Courier New"
                    TextAlignment="Right"/>
			</StackPanel>

			<!-- Help Text (Center Bottom) -->
			<TextBlock
                Canvas.Bottom="12"
                Canvas.Left="0"
                Canvas.Right="0"
                Text="LMB: Orbit | Shift+LMB: Pan | Scroll: Zoom | F: Front | T: Top | S: Side | I: Iso"
                Foreground="#FF606060"
                FontSize="10"
                TextAlignment="Center"
                Panel.ZIndex="10"
                FontStyle="Italic"/>
		</Canvas>

		<!-- Status Bar -->
		<Border
            Grid.Row="1"
            Background="#FF252525"
            BorderBrush="#FF3F3F3F"
            BorderThickness="0,1,0,0"
            Height="24"
            Padding="8,0">

			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock
                    Grid.Column="0"
                    x:Name="StatusText"
                    Text="Ready"
                    Foreground="#FFA0A0A0"
                    FontSize="11"
                    VerticalAlignment="Center"/>

				<TextBlock
                    Grid.Column="1"
                    x:Name="ViewportMode"
                    Text="Solid Mode"
                    Foreground="#FF4FC3F7"
                    FontSize="11"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"/>

				<TextBlock
                    Grid.Column="2"
                    x:Name="ViewportInfo"
                    Text="DirectX 12 | v1.0"
                    Foreground="#FFA0A0A0"
                    FontSize="11"
                    VerticalAlignment="Center"/>
			</Grid>
		</Border>
	</Grid>
</UserControl>
