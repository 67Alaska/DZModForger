<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.Controls.TransformGizmoControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="300"
    Height="Auto">

    <StackPanel Spacing="12">
        <!-- Gizmo Mode Buttons -->
        <TextBlock Text="Transform Mode" FontSize="12" FontWeight="SemiBold" />

        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="4">
            <Button 
                x:Name="NoneButton"
                Content="None"
                Click="NoneButton_Click"
                Tag="None" />

            <Button 
                Grid.Column="1"
                x:Name="MoveButton"
                Content="Move"
                Click="MoveButton_Click"
                Tag="Move" />

            <Button 
                Grid.Column="2"
                x:Name="RotateButton"
                Content="Rotate"
                Click="RotateButton_Click"
                Tag="Rotate" />

            <Button 
                Grid.Column="3"
                x:Name="ScaleButton"
                Content="Scale"
                Click="ScaleButton_Click"
                Tag="Scale" />
        </Grid>

        <Separator />

        <!-- Position Controls -->
        <StackPanel Spacing="8">
            <TextBlock Text="Position" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />

            <local:Vector3InputControl 
                x:Name="PositionInput"
                Vector3Changed="PositionInput_Vector3Changed" />
        </StackPanel>

        <!-- Rotation Controls -->
        <StackPanel Spacing="8">
            <TextBlock Text="Rotation (°)" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />

            <local:Vector3InputControl 
                x:Name="RotationInput"
                Vector3Changed="RotationInput_Vector3Changed" />
        </StackPanel>

        <!-- Scale Controls -->
        <StackPanel Spacing="8">
            <TextBlock Text="Scale" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />

            <local:Vector3InputControl 
                x:Name="ScaleInput"
                Vector3Changed="ScaleInput_Vector3Changed" />
        </StackPanel>

        <!-- Uniform Scale Toggle -->
        <CheckBox 
            x:Name="UniformScaleCheckBox"
            Content="Uniform Scale"
            IsChecked="False" />
    </StackPanel>
</UserControl>
