<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.Controls.MaterialEditorControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="300"
    Height="Auto">

    <ScrollViewer VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="12">

            <!-- Material Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="Material Name" FontSize="12" FontWeight="SemiBold" />
                <TextBox 
                    x:Name="MaterialNameInput"
                    PlaceholderText="Material"
                    TextChanged="MaterialNameInput_TextChanged"
                    Padding="8,6" />
            </StackPanel>

            <!-- Diffuse Color -->
            <StackPanel Spacing="4">
                <TextBlock Text="Diffuse Color" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />
                <local:ColorPickerControl 
                    x:Name="DiffuseColorPicker"
                    ColorChanged="DiffuseColorPicker_ColorChanged" />
            </StackPanel>

            <!-- Specular Color -->
            <StackPanel Spacing="4">
                <TextBlock Text="Specular Color" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />
                <local:ColorPickerControl 
                    x:Name="SpecularColorPicker"
                    ColorChanged="SpecularColorPicker_ColorChanged" />
            </StackPanel>

            <!-- Emissive Color -->
            <StackPanel Spacing="4">
                <TextBlock Text="Emissive Color" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />
                <local:ColorPickerControl 
                    x:Name="EmissiveColorPicker"
                    ColorChanged="EmissiveColorPicker_ColorChanged" />
            </StackPanel>

            <!-- Shininess -->
            <StackPanel Spacing="4">
                <TextBlock Text="Shininess" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />
                <local:SliderWithValueControl 
                    x:Name="ShininessSlider"
                    Minimum="0"
                    Maximum="128"
                    StepFrequency="1"
                    ValueChanged="ShininessSlider_ValueChanged" />
            </StackPanel>

            <!-- Transparency -->
            <StackPanel Spacing="4">
                <TextBlock Text="Transparency" FontSize="12" FontWeight="SemiBold" Foreground="#32a8c6" />
                <local:SliderWithValueControl 
                    x:Name="TransparencySlider"
                    Minimum="0"
                    Maximum="1"
                    StepFrequency="0.01"
                    ValueChanged="TransparencySlider_ValueChanged" />
            </StackPanel>

            <!-- Action Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button 
                    Content="Reset"
                    Click="ResetButton_Click" />

                <Button 
                    Grid.Column="1"
                    Content="Copy"
                    Click="CopyButton_Click" />
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
