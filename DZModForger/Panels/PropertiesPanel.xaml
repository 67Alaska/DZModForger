<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="DZModForger.Panels.PropertiesPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#2D2D2D"
    Foreground="#FFFFFF">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical" Spacing="16" Padding="12">

            <!-- MODEL INFO -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock
                    Text="Model"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#4FC3F7"/>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="File:" FontSize="11" Foreground="#A0A0A0"/>
                    <TextBlock x:Name="PropModelFile" Text="None" FontSize="11" Foreground="#FFFFFF"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="Vertices:" FontSize="11" Foreground="#A0A0A0"/>
                    <TextBlock x:Name="PropVertexCount" Text="0" FontSize="11" Foreground="#FFFFFF"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="Faces:" FontSize="11" Foreground="#A0A0A0"/>
                    <TextBlock x:Name="PropFaceCount" Text="0" FontSize="11" Foreground="#FFFFFF"/>
                </StackPanel>
            </StackPanel>

            <Border Background="#3F3F3F" Height="1" Margin="0,8,0,8"/>

            <!-- TRANSFORM -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock
                    Text="Transform"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#4FC3F7"/>

                <Grid ColumnSpacing="8" RowSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Position -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Pos X:" FontSize="11" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="0" Grid.Column="1" x:Name="PropPosX" Value="0" FontSize="11" SpinButtonPlacementMode="Hidden"/>

                    <!-- Rotation -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Rot X:" FontSize="11" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="1" Grid.Column="1" x:Name="PropRotX" Value="0" FontSize="11" SpinButtonPlacementMode="Hidden"/>

                    <!-- Scale -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Scale:" FontSize="11" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                    <NumberBox Grid.Row="2" Grid.Column="1" x:Name="PropScale" Value="1" FontSize="11" SpinButtonPlacementMode="Hidden"/>
                </Grid>

                <Button
                    x:Name="BtnResetTransform"
                    Content="Reset"
                    Click="BtnResetTransform_Click"
                    Padding="8,6"
                    FontSize="11"
                    Width="100"
                    HorizontalAlignment="Left"
                    Background="#404040"/>
            </StackPanel>

            <Border Background="#3F3F3F" Height="1" Margin="0,8,0,8"/>

            <!-- STATISTICS -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock
                    Text="Statistics"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="#4FC3F7"/>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="FPS:" FontSize="11" Foreground="#A0A0A0"/>
                    <TextBlock x:Name="PropFPS" Text="0" FontSize="11" Foreground="#00FF00"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="GPU Memory:" FontSize="11" Foreground="#A0A0A0"/>
                    <TextBlock x:Name="PropGPUMemory" Text="0 MB" FontSize="11" Foreground="#FFFFFF"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
