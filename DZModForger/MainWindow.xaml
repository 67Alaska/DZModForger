<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="DZModForger.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DZModForger"
    xmlns:panels="using:DZModForger.Panels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="DZModForger - 3D Model Editor"
    Closed="Window_Closed">

    <Grid Background="#1A1A1A">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP MENU BAR -->
        <Border
            Grid.Row="0"
            Background="#2D2D2D"
            BorderBrush="#3F3F3F"
            BorderThickness="0,0,0,1"
            Padding="12,0"
            Height="40">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Text="DZModForger"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="#4FC3F7"
                    VerticalAlignment="Center"/>

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">
                    <Button
                        x:Name="BtnOpenModel"
                        Content="Open Model"
                        Click="BtnOpenModel_Click"
                        Padding="12,6"
                        FontSize="12"
                        Background="#4FC3F7"
                        Foreground="#1A1A1A"/>
                    <Button
                        x:Name="BtnSave"
                        Content="Save"
                        Click="BtnSave_Click"
                        Padding="12,6"
                        FontSize="12"
                        Background="#404040"
                        Foreground="#FFFFFF"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - SCENE TREE -->
            <Border
                Grid.Column="0"
                Background="#2D2D2D"
                BorderBrush="#3F3F3F"
                BorderThickness="0,0,1,0"
                Padding="12">
                <StackPanel Orientation="Vertical" Spacing="12">
                    <TextBlock
                        Text="Scene"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#4FC3F7"/>

                    <TextBlock
                        x:Name="TxtModelFile"
                        Text="No model loaded"
                        FontSize="12"
                        Foreground="#A0A0A0"
                        TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CENTER - 3D VIEWPORT -->
            <Canvas
                Grid.Column="1"
                x:Name="ViewportCanvas"
                Background="#000000"
                Margin="8"
                PointerPressed="ViewportCanvas_PointerPressed"
                PointerReleased="ViewportCanvas_PointerReleased"
                PointerMoved="ViewportCanvas_PointerMoved"
                PointerWheelChanged="ViewportCanvas_PointerWheelChanged"/>

            <!-- RIGHT PANEL - PROPERTIES -->
            <Border
                Grid.Column="2"
                Background="#2D2D2D"
                BorderBrush="#3F3F3F"
                BorderThickness="1,0,0,0">
                <panels:PropertiesPanel/>
            </Border>
        </Grid>

        <!-- STATUS BAR -->
        <Border
            Grid.Row="2"
            Background="#252525"
            BorderBrush="#3F3F3F"
            BorderThickness="0,1,0,0"
            Height="24"
            Padding="12,0">
            <TextBlock
                x:Name="StatusText"
                Text="Ready"
                Foreground="#A0A0A0"
                FontSize="11"
                VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
